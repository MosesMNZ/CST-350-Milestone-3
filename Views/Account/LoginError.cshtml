@{
    ViewData["Title"] = "Login Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <h4 class="alert-heading">Login Failed!</h4>
                <p>@ViewBag.ErrorMessage</p>
                <hr />
                <p class="mb-0">Please verify your credentials and try again.</p>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Common Issues</h5>
                    <ul>
                        <li>Incorrect username or password</li>
                        <li>Account may not exist</li>
                        <li>Check if CAPS LOCK is on</li>
                        <li>Account may be locked due to multiple failed attempts</li>
                    </ul>

                    <div class="mt-4">
                        <a href="@Url.Action("Login", "Account")" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt"></i> Try Login Again
                        </a>
                        <a href="@Url.Action("Register", "Account")" class="btn btn-info">
                            <i class="fas fa-user-plus"></i> Create Account
                        </a>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
