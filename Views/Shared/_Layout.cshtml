<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CST_350_Milestone</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CST_350_Milestone.styles.css" asp-append-version="true" />
    <style>
        /* Fill the viewport exactly - header/footer keep their natural size,
           the content area between them takes whatever is left. This is what
           stops the Game/Win/Loss pages (and everything else) from ever
           scrolling the whole page; if a page's content is taller than the
           space available, only #main-area scrolls internally. */
        html, body { height: 100%; overflow: hidden; }
        body { display: flex; flex-direction: column; }
        header { flex-shrink: 0; }
        #main-area { flex: 1; min-height: 0; overflow-y: auto; }
        #main-area > main { height: 100%; }
        footer { flex-shrink: 0; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-0 position-relative">
            <div class="container-fluid">
                <!-- Left: Hello / Profile link -->
                @if (Context.Session.GetString("UserAuthenticated") == "true")
                {
                    <!-- ACTIVITY 6: opens the edit-profile modal via AJAX instead of navigating to a full page -->
                    <a href="#" id="editProfileLink" class="navbar-text text-dark fw-semibold text-decoration-none">Hello, @Context.Session.GetString("FirstName")</a>
                }
                else
                {
                    <span></span>
                }

                <!-- Center: absolutely anchored to the middle -->
                @if (Context.Session.GetString("UserAuthenticated") == "true")
                {
                    <a class="navbar-brand position-absolute start-50 translate-middle-x mb-0" asp-area="" asp-controller="Games" asp-action="StartGame">Milestone Minesweeper</a>
                }
                else
                {
                    <a class="navbar-brand position-absolute start-50 translate-middle-x mb-0" asp-area="" asp-controller="Account" asp-action="Login">Milestone Minesweeper</a>
                }

                <!-- Right: Logout or Login -->
                <div class="ms-auto">
                    @if (Context.Session.GetString("UserAuthenticated") == "true")
                    {
                        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Logout">Logout</a>
                    }
                    else
                    {
                        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div id="main-area">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- ACTIVITY 6 (Partial Views): empty modal shell, present on every page.
         modalHandler.js fills #editProfileModal .modal-content with the
         _EditProfileForm partial view via AJAX. -->
    <div class="modal fade" id="editProfileModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <!-- populated dynamically via AJAX -->
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CST_350_Milestone - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/modalHandler.js" asp-append-version="true"></script>
    <script src="~/js/formHandler.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
